{
  "name": "bookhub",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "vite build && wrangler pages deploy dist --project-name=bookhub",
    "db:init:local": "wrangler d1 execute bookhub-db --local --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute bookhub-db --remote --file=./schema.sql"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.10",
    "wrangler": "^3.90.0"
  }
}
